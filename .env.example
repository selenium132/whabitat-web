; ===========================================
; Whabitat Web - Environment Configuration Template
; ===========================================
; Copy this file to .env and fill in your values.
; NEVER commit the .env file to version control!

; Database Configuration
DB_HOST=localhost
DB_NAME=your_database_name
DB_USER=your_database_user
DB_PASS=your_database_password

; Circle Secret Code (for registration)
CIRCLE_SECRET=your_circle_secret
ADMIN_SECRET=your_admin_secret

; API Key for Google Forms Sync
API_KEY=your_api_key

; LINE Login Configuration
LINE_CHANNEL_ID=your_line_channel_id
LINE_CHANNEL_SECRET=your_line_channel_secret
LINE_CALLBACK_URL=https://yourdomain.com/callback.php

; LINE Messaging API (Bot) Configuration
LINE_BOT_ACCESS_TOKEN=your_bot_access_token
LINE_BOT_CHANNEL_SECRET=your_bot_channel_secret

; reCAPTCHA v2 Configuration
RECAPTCHA_SITE_KEY=your_recaptcha_site_key
RECAPTCHA_SECRET_KEY=your_recaptcha_secret_key

; Google Service Account JSON path (relative to project root)
GOOGLE_SERVICE_ACCOUNT_PATH=service-account.json
